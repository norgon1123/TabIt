{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: dev (reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload"],
      "jinja": false,
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI: debug (no reload)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app"],
      "jinja": false,
      "justMyCode": false,
      "console": "integratedTerminal"
    }
  ]
}
