# Python
__pycache__/
*.py[cod]
# No trailing slash: in a worktree, scripts/setup-worktree.sh makes .venv a SYMLINK to the
# root checkout's venv, and `.venv/` (dir-only) would not match a symlink.
.venv
*.egg-info/
.pytest_cache/

# Local settings overrides (see .env.example)
.env

# Database (local SQLite)
tabit.db

# Frontend build output
frontend/dist/
frontend/tsconfig.tsbuildinfo

# Local uploaded audio storage
storage/

# Generated eval stem datasets (derived from tests/eval via scripts/make_eval_stems.py)
tests/eval-stems/

# Vendored BTC model weights — staged out of band on the inference box, not committed
# (large; see vendor/btc/README.md). The inference source under vendor/btc/ IS tracked.
vendor/btc/weights/

# OS / editor
.DS_Store
.idea/

# Local Claude worktrees
.claude/worktrees/

# Visual brainstorming companion mockups
.superpowers/
