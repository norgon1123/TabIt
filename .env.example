# Tabit local settings. Copy to .env (git-ignored) and edit; every key maps to a field on
# app.config.Settings, so `TABIT_<FIELD>` overrides the default there. The backend reads
# .env at startup — restart uvicorn after changing it.

# --- Chord engine -------------------------------------------------------------------
# chordino | librosa | btc
#   chordino  Tier 2 Vamp plugin + Viterbi (default; falls back to librosa if missing)
#   librosa   built-in HPSS chroma + Viterbi, no extra deps
#   btc       pretrained BTC transformer; needs `pip install -e ".[ml]"` and the weights
#             staged under vendor/btc/weights/ (see vendor/btc/README.md)
TABIT_ANALYSIS_ENGINE=chordino

# --- Demucs separation (only consumed by the btc engine today) -----------------------
# true => separate the upload with Demucs and transcribe chords from the harmonic stem
# instead of the raw mix. Costs a GPU pass per upload; requires the ".[ml]" extra.
TABIT_ENABLE_SEPARATION=false
TABIT_SEPARATION_MODEL=htdemucs_6s
# harmonic (guitar+piano+other) | accomp (+bass) | full | explicit list e.g. guitar,piano
TABIT_SEPARATION_STEMS=harmonic
# auto (cuda -> mps -> cpu) | cuda | mps | cpu
TABIT_ANALYSIS_DEVICE=auto

# --- Shared analysis tuning ----------------------------------------------------------
TABIT_ANALYSIS_MIN_SEGMENT_SECONDS=0.75
# librosa engine only:
TABIT_ANALYSIS_CHANGE_PENALTY=1.0
TABIT_ANALYSIS_USE_HPSS=true
